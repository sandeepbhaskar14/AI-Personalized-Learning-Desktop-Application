                                       <item>
                                        <widget class="QComboBox" name="comboBox">
                                         <property name="minimumSize">
                                          <size>
                                           <width>121</width>
                                           <height>35</height>
                                          </size>
                                         </property>
                                         <property name="maximumSize">
                                          <size>
                                           <width>250</width>
                                           <height>16777215</height>
                                          </size>
                                         </property>
                                         <property name="font">
                                          <font>
                                           <family>Roboto Medium</family>
                                           <pointsize>9</pointsize>
                                          </font>
                                         </property>
                                         <property name="styleSheet">
                                          <string notr="true">/* Main QComboBox box */
QComboBox {
    border: 2px solid rgb(55, 61, 75);
	color: rgb(190, 190, 190);
    border-radius: 5px;
    padding: 1px 18px 1px 3px;
    min-width: 6em;
    background: rgb(55, 61, 75);
}

QComboBox:hover{
	border: 2px solid rgba(0, 170, 255, 70);
}

/* Drop-down button (the container for the arrow) */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 15px;
    border:none;
	padding-right: 10px;
}

/* Arrow inside the drop-down button */
QComboBox::down-arrow {
    image: url(../Reqs/down-arrow.png); /* Use a custom image */
	min-width:10px;
}

/* The actual list of items (popup) */
QComboBox QAbstractItemView {
    border: 2px solid darkgray;
    selection-background-color: lightgray;
    background-color: rgb(59, 65, 80);
}
</string>
