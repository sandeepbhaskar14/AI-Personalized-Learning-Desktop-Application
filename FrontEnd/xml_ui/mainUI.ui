                                   <property name="maximumSize">
                                    <size>
                                     <width>61</width>
                                     <height>31</height>
                                    </size>
                                   </property>
                                   <property name="styleSheet">
                                    <string notr="true">QSpinBox {
    background-color: transparent;
    border: 1px solid rgb(139, 139, 139);
    border-radius: 6px;
    padding: 4px 15px 4px 8px;  /* space for arrows */
    font-size: 14px;
    color: rgb(200, 200, 200);
}

QSpinBox:hover {
    border: 1px solid #90caf9;
}

QSpinBox:focus {
    border: 1px solid #42a5f5;
}

/* Up &amp; Down buttons */
QSpinBox::up-button,
QSpinBox::down-button {
    width: 18px;
    background-color: transparent;
    border: none;
}

QSpinBox::up-button:hover,
QSpinBox::down-button:hover {
    background-color: rgb(56, 63, 77);
    border-radius: 4px;
}

/* Arrows */
QSpinBox::up-arrow {
    image: none;
    width: 0;
    height: 0;
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    border-bottom: 6px solid #546e7a;
}

QSpinBox::down-arrow {
    image: none;
    width: 0;
    height: 0;
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    border-top: 6px solid #546e7a;
}

/* Disabled state */
QSpinBox:disabled {
    background-color: #f5f5f5;
    color: #9e9e9e;
    border: 1px solid #e0e0e0;
}
</string>
                                   </property>
                                  </widget>
