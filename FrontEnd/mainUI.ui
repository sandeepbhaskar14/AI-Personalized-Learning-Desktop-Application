background:transparent;
padding-top:15px;</string>
                                   </property>
                                   <property name="text">
                                    <string>&lt;span style=&quot;font-size:18px;&quot;&gt;Daily goal H:M&lt;/span&gt;&lt;br&gt;
&lt;span style=&quot;font-size:16px;color:rgb(150, 150, 150)&quot;&gt;Set your daily goal example 1 hour, 30 min etc&lt;/span&gt;&lt;br&gt;
</string>
                                   </property>
