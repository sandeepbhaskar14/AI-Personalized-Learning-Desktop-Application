background:transparent;
padding-top:15px;</string>
                                   </property>
                                   <property name="text">
                                    <string>&lt;span style=&quot;font-size:18px;&quot;&gt;Learning style&lt;/span&gt;&lt;br&gt;
&lt;span style=&quot;font-size:16px;color:rgb(150, 150, 150)&quot;&gt;Choose your learning style as visual/text/quiz&lt;/span&gt;&lt;br&gt;
</string>
                                   </property>
